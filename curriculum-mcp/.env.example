# Supabase (service role — SERVER-SIDE ONLY, never ship to browser)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# MCP transport
# streamable-http (default, for remote clients) or stdio (for local dev)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Transport security (DNS rebinding protection).
# Leave BOTH blank to disable the Host/Origin allow-list (recommended when
# you rely on CURRICULUM_MCP_TOKEN + Supabase RLS for auth; the MCP SDK does
# NOT treat "*" as a wildcard, so a bare "*" would block every request).
# To re-enable, set an exact comma-separated list, e.g.:
#   MCP_ALLOWED_HOSTS=mcp-curriculum.up.railway.app
#   MCP_ALLOWED_ORIGINS=https://your-frontend.example.com
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=
