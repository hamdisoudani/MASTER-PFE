{
  "dependencies": [
    "./agent"
  ],
  "graphs": {
    "syllabus_agent": "./agent/graph.py:graph",
    "syllabus_agent_deep": "./agent/deep_graph.py:graph"
  },
  "env": "./agent/.env",
  "python_version": "3.11",
  "http": {
