# ── LLM Configuration ──────────────────────────────────────────
# Provider: openai | anthropic | google | custom
LLM_PROVIDER=openai

# Model name (e.g. gpt-4o, claude-3-5-sonnet-20241022, gemini-1.5-pro)
LLM_MODEL=gpt-4o

# API key for the chosen provider
LLM_API_KEY=your_api_key_here

# (Optional) Custom base URL for proxied / local LLMs (OpenAI-compatible)
LLM_BASE_URL=

# ── Server ─────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# ── LangSmith (optional) ───────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=master-pfe-agent
