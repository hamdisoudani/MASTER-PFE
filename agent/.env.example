# NVIDIA NIM
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=
LLM_MODEL=mistralai/mistral-small-4-119b-2603

# Web search / scraping
SERPER_API_KEY=

# Pusher (tool-bridge transport — test creds live in workspace/secrets.json)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# Curriculum MCP server (FastMCP streamable-http endpoint).
# Leave blank to disable the curriculum tools (agent falls back to web_search/scrape only).
# Local dev: http://localhost:8080/mcp  — Railway: https://<service>.up.railway.app/mcp
CURRICULUM_MCP_URL=
# Optional bearer token if curriculum-mcp is protected (sent as Authorization: Bearer ...).
CURRICULUM_MCP_TOKEN=
